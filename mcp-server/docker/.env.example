# ============================================================
# MaxVision LinkedIn MCP — .env.example
# Copiar para .env e preencher antes de subir Compose ou Portainer Stack.
# Para Swarm via CLI, secrets devem ser criados via `docker secret create`,
# este arquivo serve apenas para variáveis NÃO-sensíveis ou Compose mode.
# ============================================================

# --- Versão e identidade ---
MCP_VERSION=latest
MCP_HOST=linkedin-mcp.seu-dominio.com
MCP_PORT=3000
MCP_METRICS_PORT=9090
MCP_REPLICAS=1

# --- Logs e telemetria ---
LOG_LEVEL=info
MAXVISION_TELEMETRY=on

# --- Banco de dados ---
POSTGRES_USER=mcp
POSTGRES_PASSWORD=trocar-aqui-para-password-forte
POSTGRES_DB=mcp

# --- Segurança / criptografia ---
# Gerar com: openssl rand -hex 32
MASTER_KEY=trocar-para-chave-mestre-aes-256-gcm

# Gerar com: openssl rand -hex 32
WEBHOOK_SECRET=trocar-para-secret-webhook

# --- License key (Pro/Agency apenas) ---
# Deixar vazio para tier Free
LICENSE_KEY=

# --- Cookies LinkedIn ---
# JSON inline com cookies (NÃO usar em produção, preferir Docker secret)
# Formato: {"default":"AQED...","backup":"AQED..."}
LI_COOKIES_JSON={"default":"COLE-AQUI-O-COOKIE-LI_AT"}

# --- Webhooks / SSE ---
ENABLE_WEBHOOKS=true
SSE_ENABLED=true

# --- Patchright ---
PATCHRIGHT_HEADLESS=true

# --- Traefik / TLS ---
ACME_RESOLVER=letsencrypt
