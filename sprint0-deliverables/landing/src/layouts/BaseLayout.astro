---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "MaxVision LinkedIn Suite",
  description = "Automação LinkedIn nativa para Claude Code: busca de vagas, candidatura, outreach e otimização de perfil.",
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <title>{title}</title>
  </head>
  <body class="bg-brand-900 text-slate-100 font-sans antialiased">
    <slot />
  </body>
</html>
