{
  "name": "@maxvision/linkedin-landing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MaxVision LinkedIn Suite — landing page (Cloudflare Pages)",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "start": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev ./dist --compatibility-date=2026-05-08",
    "deploy": "astro build && wrangler pages deploy ./dist --project-name=linkedin-maxvision-landing",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^11.2.0",
    "@astrojs/tailwind": "^5.1.0",
    "astro": "^5.1.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.96.0"
  }
}
