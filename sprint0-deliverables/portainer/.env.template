# ============================================================
# MaxVision LinkedIn MCP — Environment Variables (Portainer)
# Copy to Portainer → Stacks → maxv-linkedin → Environment variables
# ============================================================

# --- Routing ---
MCP_HOST=linkedin-mcp.produtoramaxvision.com.br
ACME_EMAIL=produtoramaxvision@gmail.com

# --- Image version ---
# Atualizar quando CI publicar nova tag em ghcr.io/produtoramaxvision/linkedin-maxvision-mcp
MCP_VERSION=0.1.0

# --- Replicas / scaling ---
MCP_REPLICAS=1

# --- Logs / telemetry ---
LOG_LEVEL=info
MAXVISION_TELEMETRY=on

# --- Webhooks / SSE ---
ENABLE_WEBHOOKS=true
SSE_ENABLED=true

# ============================================================
# SECRETS (gerar localmente, NÃO commitar)
# Comandos para gerar:
#   openssl rand -hex 32        # POSTGRES_PASSWORD, MASTER_KEY, WEBHOOK_SECRET
# ============================================================

POSTGRES_PASSWORD=<openssl rand -hex 32>
MASTER_KEY=<openssl rand -hex 32>
WEBHOOK_SECRET=<openssl rand -hex 32>

# License — vazio em sandbox; preenche quando tier Pro estiver live (Sprint 3+)
LICENSE_KEY=

# LinkedIn cookie JSON (extrair via DevTools → Application → Cookies → li_at, JSESSIONID)
# Formato: [{"name":"li_at","value":"...","domain":".linkedin.com","path":"/"}, ...]
LI_COOKIES_JSON=
