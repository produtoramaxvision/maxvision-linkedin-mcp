---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="MaxVision LinkedIn Suite — Em breve"
  description="Automação LinkedIn nativa para Claude Code. Busca, aplica, otimiza e converte sem você abrir o navegador."
>
  <main class="min-h-screen flex flex-col items-center justify-center px-6 py-16">
    <section class="max-w-3xl w-full mx-auto text-center">
      <p class="uppercase tracking-widest text-xs text-brand-100/70 mb-4">
        MaxVision · LinkedIn Suite
      </p>
      <h1
        class="text-4xl md:text-6xl font-extrabold leading-tight tracking-tight mb-6"
      >
        Seu LinkedIn no
        <span class="text-brand-500">Claude Code</span>.
      </h1>
      <p
        class="text-lg md:text-xl text-slate-300 mb-10 max-w-2xl mx-auto leading-relaxed"
      >
        Busca de vagas, candidatura inteligente, outreach com aprovação humana
        e otimização de perfil — tudo num plugin Claude Code com browser
        anti-detect production-grade. <strong>Em breve.</strong>
      </p>

      <form
        id="waitlist-form"
        class="flex flex-col sm:flex-row gap-3 max-w-xl mx-auto"
      >
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder="seu@email.com"
          class="flex-1 px-4 py-3 rounded-lg bg-slate-800/60 border border-slate-700 text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500"
        />
        <button
          type="submit"
          class="px-6 py-3 rounded-lg bg-brand-500 hover:bg-brand-600 transition-colors font-semibold"
        >
          Entrar na waitlist
        </button>
      </form>

      <p
        id="waitlist-status"
        class="mt-4 text-sm text-slate-400 min-h-5"
        aria-live="polite"
      >
      </p>

      <p class="text-xs text-slate-500 mt-12 max-w-xl mx-auto leading-relaxed">
        MaxVision LinkedIn Suite executa ações em sua conta LinkedIn via cookie
        de sessão. Automação no LinkedIn pode violar os Termos de Uso da
        plataforma e resultar em restrições de conta. Use com moderação e por
        sua conta e risco.
      </p>
    </section>

    <footer class="mt-16 text-xs text-slate-500 text-center">
      <p>
        © 2026 Produtora MaxVision ·
        <a
          href="https://github.com/produtoramaxvision/maxvision-linkedin-mcp"
          class="hover:text-brand-100 underline"
        >
          GitHub
        </a>
      </p>
    </footer>
  </main>

  <script is:inline>
    const form = document.getElementById("waitlist-form");
    const statusEl = document.getElementById("waitlist-status");
    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const email = new FormData(form).get("email");
      statusEl.textContent = "Enviando...";
      try {
        const res = await fetch("/api/waitlist", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ email }),
        });
        if (!res.ok) throw new Error(`http ${res.status}`);
        statusEl.textContent = "Recebido! Entraremos em contato em breve.";
        form.reset();
      } catch (err) {
        statusEl.textContent =
          "Erro ao enviar. Tente novamente em alguns minutos.";
        console.error(err);
      }
    });
  </script>
</BaseLayout>
